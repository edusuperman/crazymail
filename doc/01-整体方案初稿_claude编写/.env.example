# CrazyMail 环境变量模板
# 复制为 .env 并填入真实值，永远不要将 .env 提交到 Git

# ══════════════════════════════════════
# LLM API Keys
# ══════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-xxxx
DEEPSEEK_API_KEY=sk-xxxx
OPENAI_API_KEY=sk-xxxx          # 可选，部分工具需要
GROK_API_KEY=xai-xxxx           # 可选

# 本地 Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b

# ══════════════════════════════════════
# 数据库
# ══════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/crazymail
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJxxxx
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════
# SEO 工具 API
# ══════════════════════════════════════
ORIGINALITY_AI_API_KEY=xxxx      # AI检测
SURFER_SEO_API_KEY=xxxx          # SEO评分
AHREFS_API_KEY=xxxx              # 关键词/外链
SEMRUSH_API_KEY=xxxx             # 竞争分析

# Google APIs
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
GOOGLE_SEARCH_CONSOLE_PROPERTY=https://yourdomain.com

# ══════════════════════════════════════
# 代理配置
# ══════════════════════════════════════
BRIGHTDATA_USERNAME=xxxx
BRIGHTDATA_PASSWORD=xxxx
BRIGHTDATA_HOST=zproxy.lum-superproxy.io
BRIGHTDATA_PORT=22225

# ══════════════════════════════════════
# 指纹浏览器
# ══════════════════════════════════════
DOLPHIN_ANTY_API_TOKEN=xxxx
DOLPHIN_ANTY_API_URL=http://localhost:3001/v1.0

# ══════════════════════════════════════
# 应用配置
# ══════════════════════════════════════
SECRET_KEY=your-secret-key-min-32-chars
ENVIRONMENT=development          # development / production
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# 金牌告警通知
ALERT_EMAIL=your@email.com
PUSHOVER_TOKEN=xxxx              # 可选，手机推送
PUSHOVER_USER=xxxx

# ══════════════════════════════════════
# 内容生产配置
# ══════════════════════════════════════
CONTENT_PIPELINE_CONCURRENCY=3   # 同时跑几个流水线
QA_AI_DETECTION_THRESHOLD=30     # 低于此分通过
QA_SEO_SCORE_THRESHOLD=75        # 高于此分通过
QA_MAX_RETRIES=3                 # 质检失败最多重写次数
HUMAN_REVIEW_ENABLED=true        # 是否启用宋徽宗审核节点

# 主力写作模型（可按需切换）
WRITING_MODEL_PRIMARY=claude-3-5-sonnet-20241022
WRITING_MODEL_FALLBACK=deepseek-chat
RESEARCH_MODEL=deepseek-chat     # 研究/大纲用低成本模型

# ══════════════════════════════════════
# 皇城司配置
# ══════════════════════════════════════
ISOLATION_SCAN_ENABLED=true
ISOLATION_SCAN_SCHEDULE=0 6 * * *   # 每天早6点扫描（cron格式）
GOLD_MEDAL_WEBHOOK_URL=https://hooks.slack.com/xxxx  # 可选

# ══════════════════════════════════════
# 人格系统配置
# ══════════════════════════════════════
PERSONA_HUMAN_FEEL_HEROES=0.85
PERSONA_HUMAN_FEEL_OFFICIALS=0.35
PERSONA_PROFILES_PATH=backend/personas
