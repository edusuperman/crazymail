# CrazyMail 环境变量模板
# 复制为 .env 并填入真实值，永远不要将 .env 提交到 Git

# ══════════════════════════════════════
# LLM API Keys
# ══════════════════════════════════════
MIMO_API_KEY=tp-xxxx
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

AGNES_API_KEY=sk-xxxx
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# ══════════════════════════════════════
# 数据库
# ══════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://postgres.usapdnuwomunzjelciwi:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://usapdnuwomunzjelciwi.supabase.co
SUPABASE_KEY=eyJxxxx
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════
# 外部服务
# ══════════════════════════════════════
ORIGINALITY_AI_API_KEY=xxxx
GOOGLE_SEARCH_CONSOLE_API_KEY=xxxx

# ══════════════════════════════════════
# 通知（可选）
# ══════════════════════════════════════
SLACK_WEBHOOK_URL=https://hooks.slack.com/xxxx

# ══════════════════════════════════════
# 内容生产配置
# ══════════════════════════════════════
CONTENT_PIPELINE_CONCURRENCY=3
QA_AI_DETECTION_THRESHOLD=30
QA_SEO_SCORE_THRESHOLD=75
QA_MAX_RETRIES=3
HUMAN_REVIEW_ENABLED=true

# 主力写作模型
WRITING_MODEL_PRIMARY=mimo-v2.5-pro
WRITING_MODEL_FALLBACK=agnes-2.0-flash
RESEARCH_MODEL=agnes-2.0-flash

# ══════════════════════════════════════
# 皇城司配置
# ══════════════════════════════════════
ISOLATION_SCAN_ENABLED=true
ISOLATION_SCAN_SCHEDULE=0 6 * * *

# ══════════════════════════════════════
# 人格系统配置
# ══════════════════════════════════════
PERSONA_HUMAN_FEEL_HEROES=0.85
PERSONA_HUMAN_FEEL_OFFICIALS=0.35
PERSONA_PROFILES_PATH=backend/personas
